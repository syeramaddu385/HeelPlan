DATABASE_URL=postgresql+psycopg://schedule:schedule@localhost:5432/schedulebuilder

# Gemini API configuration
# Get your free API key from: https://aistudio.google.com/app/apikey
# ⚠️  NEVER commit your actual API key to version control!
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Constraints database path (defaults to .constraints.json in backend directory)
CONSTRAINTS_DB=.constraints.json